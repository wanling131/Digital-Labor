{
  "name": "数字劳务",
  "version": "1.0.0",
  "private": true,
  "description": "数字劳务管理平台（前后端分离）",
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "cd server && npm run dev",
    "dev:web": "cd web && npm run dev",
    "build": "npm run build:web",
    "build:web": "cd web && npm run build",
    "start": "npm run start:server",
    "start:server": "cd server && npm run start",
    "install:all": "npm install && cd server && npm install && cd ../web && npm install",
    "test": "npm run test:server",
    "test:server": "cd server && npm test",
    "test:web": "cd web && npm run build",
    "test:connectivity": "node scripts/connectivity-test.mjs",
    "test:all": "npm run test:server && npm run test:web",
    "seed": "cd server && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
