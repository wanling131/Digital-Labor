# ============================================
# 数字劳务管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# 系统配置
# ============================================

# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 运行环境：development | production（生产环境必须设置为 production）
ENV=development

# 后端服务端口
PORT=3000

# ============================================
# 安全配置（生产环境必须修改！）
# ============================================

# JWT 密钥 - 生产环境必须使用随机密钥
# 生成命令: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-change-in-production

# 敏感数据加密密钥（身份证、手机号等加密存储）
# 生成命令: openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 连接字符串
# 格式: postgresql+psycopg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg://postgres:your-secure-password@localhost:5432/digital_labor

# SQLite 开发数据库（可选，用于本地开发）
# DATABASE_URL=sqlite:///./digital_labor.db

# ============================================
# CORS 跨域配置
# ============================================

# 允许的前端域名，多个用逗号分隔
# 生产环境示例: https://example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# ============================================
# 阿里云人脸识别配置（可选）
# ============================================

# 阿里云 AccessKey
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 人脸库配置
ALIYUN_FACE_DB_NAME=digital_labor_face
ALIYUN_FACE_CONFIDENCE_THRESHOLD=60.48

# ============================================
# Redis 缓存配置（可选）
# ============================================

REDIS_URL=redis://localhost:6379/0

# ============================================
# Token 配置
# ============================================

# Token 版本（用于强制刷新）
TOKEN_VERSION=1

# 是否使用 httpOnly cookie 存储 token（更安全）
USE_HTTPONLY_COOKIE=false

# ============================================
# 电子签章配置（可选，e签宝）
# ============================================

# ESIGN_APP_ID=
# ESIGN_APP_SECRET=
# ESIGN_ENDPOINT=https://openapi.esign.cn

# ============================================
# 短信服务配置（可选）
# ============================================

# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=
