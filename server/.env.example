# ============================================
# 数字劳务管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# 配置优先级说明
# ============================================
# ✅ 必需：不配置系统无法正常运行
# ⚠️ 推荐：不配置可运行，但存在安全风险或功能受限
# ⭕ 可选：不配置不影响核心功能

# ============================================
# 一、基础配置
# ============================================

# 运行环境
# - development: 开发环境（默认）
# - production: 生产环境（必须设置）
ENV=development

# 后端服务端口（默认 3000）
PORT=3000

# 日志级别：DEBUG | INFO | WARNING | ERROR（默认 INFO）
LOG_LEVEL=INFO

# ============================================
# 二、数据库配置 ✅ 必需
# ============================================
# 不配置将无法启动服务

# PostgreSQL 连接字符串（生产环境推荐）
# 格式: postgresql+psycopg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg://postgres:your-secure-password@localhost:5432/digital_labor

# SQLite 开发数据库（开发环境可用，取消注释即可使用）
# DATABASE_URL=sqlite:///./database/demo.sqlite3

# ============================================
# 三、安全配置 ⚠️ 推荐
# ============================================
# 开发环境：可使用默认值
# 生产环境：必须设置强随机密钥，否则存在严重安全风险

# JWT 密钥 - 用于签发登录令牌
# 生成命令: openssl rand -hex 32
# 风险：使用默认值时，攻击者可伪造任意用户身份
JWT_SECRET=your-jwt-secret-change-in-production

# 敏感数据加密密钥 - 加密身份证、手机号、银行卡等
# 生成命令: openssl rand -hex 32
# 风险：不设置时敏感数据明文存储，不符合数据安全规范
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Token 版本（用于强制使旧 token 失效）
TOKEN_VERSION=1

# ============================================
# 四、阿里云人脸识别 ⭕ 可选
# ============================================
# 不配置时使用 mock 模式，功能可测试但非真实验证
# 配置后可启用人脸实名认证、活体检测等真实功能

# 阿里云 AccessKey（账号级别，一个账号只有一对）
# 获取地址：https://ram.console.aliyun.com/manage/ak
# 注意：这是您的账号凭证，请妥善保管，不要泄露
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# 人脸库配置
ALIYUN_FACE_DB_NAME=digital_labor_face
ALIYUN_FACE_CONFIDENCE_THRESHOLD=60.48

# 验证是否生效：
# 启动后访问 GET /api/sys/feature-status
# faceVerify 为 "aliyun" 表示已接入，"mock" 表示使用模拟

# ============================================
# 五、电子签章（e签宝）⭕ 可选
# ============================================
# 不配置时使用本地 PDF 签署，功能可用但无第三方存证
# 配置后可获得法律效力的电子签名

# 获取地址：https://open.esign.cn/
# ESIGN_APP_ID=
# ESIGN_APP_SECRET=
# ESIGN_ENDPOINT=https://openapi.esign.cn

# ============================================
# 六、Redis 缓存 ⭕ 可选
# ============================================
# 不配置时无缓存，性能略有下降但不影响功能
# 配置后可提升接口响应速度

REDIS_URL=redis://localhost:6379/0

# ============================================
# 七、短信服务 ⭕ 可选
# ============================================
# 不配置时无法发送短信通知
# 功能影响：验证码、通知短信无法发送

# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# ============================================
# 八、CORS 跨域配置
# ============================================

# 允许的前端域名，多个用逗号分隔
# 开发环境可用 * 允许所有
# 生产环境建议指定具体域名
CORS_ALLOW_ORIGINS=*

# ============================================
# 快速配置指南
# ============================================

# 【开发环境 - 最简配置】
# 只需配置数据库，其他使用默认值即可启动
# DATABASE_URL=sqlite:///./database/demo.sqlite3

# 【开发环境 - 完整配置】
# DATABASE_URL=sqlite:///./database/demo.sqlite3
# JWT_SECRET=dev-secret-key-at-least-32-characters
# ENCRYPTION_KEY=dev-encryption-key-32-characters

# 【生产环境 - 必须配置】
# ENV=production
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db
# JWT_SECRET=<openssl rand -hex 32 生成的值>
# ENCRYPTION_KEY=<openssl rand -hex 32 生成的值>
# CORS_ALLOW_ORIGINS=https://your-domain.com
