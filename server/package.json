{
  "name": "digital-labor-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "node --test test/api.test.mjs test/features.test.mjs",
    "test:api": "node --test test/api.test.mjs",
    "test:features": "node --test test/features.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "node test/run-tests.js all",
    "test:report": "node test/generate-report.js",
    "seed": "node scripts/seed.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "xlsx": "^0.18.5"
  }
}
